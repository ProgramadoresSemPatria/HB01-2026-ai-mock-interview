# backend (Express) - copy to backend/.env for local development.
# frontend (Next.js): see frontend/.env.example - NEXT_PUBLIC_SERVER_URL must match this server's base URL (ex.: http://localhost:3000).

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hackathon2026

# Server Configuration
PORT=3000
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001
NODE_ENV=development

# JWT Configuration (Borderless access tokens verified by Express)
BORDERLESS_JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20
# AI-specific rate limiting (window in ms, max requests per window)
RATE_LIMIT_AI_WINDOW_MS=900000
RATE_LIMIT_AI_MAX=60

# Token usage limits (monthly per user, UTC calendar month)
TOKEN_LIMIT_ENABLED=true
TOKEN_LIMIT_MONTHLY_MAX=500000

# OpenAI (mock interview)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL_INTERVIEW=gpt-5
OPENAI_MODEL_EXTRACTION=gpt-5-nano
OPENAI_MODEL_REVIEW=gpt-5-nano

# AssemblyAI (speech-to-text)
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# Review sessions (questions per review item, default 3)
REVIEW_SESSION_QUESTION_COUNT=3

# Cloudflare R2 (object storage)
# R2_ENDPOINT is optional; defaults to https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Résumé uploads (max file size in bytes, default 5 MB)
RESUME_MAX_BYTES=5242880

# Transcription uploads (max file size in bytes, default 5 MB)
TRANSCRIBE_MAX_BYTES=5242880
