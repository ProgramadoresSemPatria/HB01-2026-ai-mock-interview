{
  "name": "hackathon2026",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "bcrypt": "^6.0.0",
      "jsonwebtoken": "^9.0.2",
      "nodemailer": "^7.0.3",
      "express-rate-limit": "^8.0.1",
      "vitest": "^3.2.4",
      "@vitest/coverage-v8": "^3.2.4",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.6.11",
      "@types/express": "^5.0.1",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "sonner": "^2.0.5",
      "@trpc/client": "^11.16.0",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "start": "turbo -F server dev",
    "test": "bunx vitest",
    "test:unit": "bunx vitest run",
    "test:ci": "bunx vitest run --coverage",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @hackathon2026/db db:push",
    "db:studio": "turbo -F @hackathon2026/db db:studio",
    "db:generate": "turbo -F @hackathon2026/db db:generate",
    "db:migrate": "turbo -F @hackathon2026/db db:migrate",
    "db:start": "turbo -F @hackathon2026/db db:start",
    "db:watch": "turbo -F @hackathon2026/db db:watch",
    "db:stop": "turbo -F @hackathon2026/db db:stop",
    "db:down": "turbo -F @hackathon2026/db db:down",
    "prepare": "husky"
  },
  "dependencies": {
    "@hackathon2026/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@hackathon2026/config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "catalog:",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^6.4.17",
    "@vitest/coverage-v8": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,astro,svelte}": ""
  },
  "packageManager": "bun@1.3.5"
}
