# Database
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hackathon2026

# Server Configuration
# Port where the Express server will listen
PORT=3000

# CORS allowed origin (frontend URL)
CORS_ORIGIN=http://localhost:3001

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3001

# Node environment
NODE_ENV=development

# JWT Configuration
# Secret key for signing JWT tokens (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# JWT access token expiration time
JWT_EXPIRE_IN=15m

# Refresh token expiration time in seconds (default: 7 days = 604800)
REFRESH_EXPIRES=604800

# Reset password JWT expiration time
RESET_PASSWORD_JWT_EXPIRE_IN=1h

# SMTP / Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=your-email@gmail.com

# Rate Limiting
# Time window for rate limiting in milliseconds (default: 15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window per IP (default: 20)
RATE_LIMIT_MAX=20
